# Copy to .env for local dev. For production, set the same keys in
# Vercel → Project Settings → Environment Variables (Production scope,
# plus Preview/Development if you want those environments to work too).

# Supabase — browser-exposed (VITE_ prefix ships them to the bundle).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic — server-only. Do NOT add a VITE_ prefix; that would leak
# the key to every visitor. Used by api/[action].js on Vercel and by
# vite dev-server middleware locally (api-plugin.js).
ANTHROPIC_API_KEY=
